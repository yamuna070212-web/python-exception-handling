try:
    a = int(input("Enter First Number: "))
    b = int(input("Enter Second Number: "))

    op = input("Enter Operator (+,-,*,/): ")

    if op == "+":
        print(a + b)

    elif op == "-":
        print(a - b)

    elif op == "*":
        print(a * b)

    elif op == "/":
        print(a / b)

    else:
        raise ValueError("Invalid Operator")
except ZeroDivisionError:
    print("Division by Zero")

except ValueError as e:
    print(e)
