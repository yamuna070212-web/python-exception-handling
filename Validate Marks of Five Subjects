try:
    marks = []

    for i in range(5):

        m = int(input(f"Subject {i+1}: "))

        if m < 0 or m > 100:
            raise ValueError("Marks must be between 0 and 100")

        marks.append(m)

    print("Average =", sum(marks) / 5)

except ValueError as e:
    print(e)
